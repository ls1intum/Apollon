{
  "compilerOptions": {
    // The host bundle is emitted as CJS by Vite, but resolution is the bundler's,
    // so `@tumaet/apollon`'s ESM type entry resolves for the type-only imports.
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["webview", "node_modules", "dist"]
}
