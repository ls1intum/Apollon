{
  "name": "apollon-vscode",
  "displayName": "Apollon",
  "description": "Embeddable UML modeling editor for VS Code. Create, edit, and export UML diagrams (class, component, activity, BPMN, and more) directly inside your editor.",
  "publisher": "tumaet",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.86.0",
    "node": ">=24.15.0"
  },
  "categories": [
    "Other"
  ],
  "vsce": {
    "dependencies": false
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "apollonEditor.openDiagram",
        "title": "Open Diagram",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "apollonEditor.openDiagram",
          "when": "resourceExtname == .apollon",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "apollon",
          "title": "Apollon",
          "icon": "media/apollon-icon.svg"
        }
      ]
    },
    "views": {
      "apollon": [
        {
          "type": "webview",
          "id": "menu",
          "name": ""
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build:all",
    "compile": "vite build",
    "watch": "vite build --watch",
    "build": "NODE_ENV=production vite build",
    "lint": "eslint src editor/src menu/src",
    "lint:fix": "eslint --fix src editor/src menu/src",
    "package:vsix": "vsce package --no-dependencies",
    "start:menu": "pnpm --filter apollon-vscode-menu run start",
    "start:editor": "pnpm --filter apollon-vscode-editor run start",
    "build:webviews": "pnpm --filter apollon-vscode-menu run build && pnpm --filter apollon-vscode-editor run build",
    "build:all": "pnpm run build && pnpm run build:webviews"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "@types/vscode": "~1.86.0",
    "@vitejs/plugin-react": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "globals": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:"
  },
  "dependencies": {
    "@tumaet/apollon": "workspace:*"
  },
  "bugs": {
    "url": "https://github.com/ls1intum/Apollon/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ls1intum/Apollon.git",
    "directory": "vscode-extension"
  }
}
