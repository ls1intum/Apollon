{
  "name": "apollon-vscode",
  "displayName": "Apollon",
  "description": "Embeddable UML modeling editor for VS Code. Create, edit, and export UML diagrams (class, component, activity, BPMN, and more) directly inside your editor.",
  "publisher": "tumaet",
  "license": "MIT",
  "version": "1.0.0",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Visualization",
    "Programming Languages"
  ],
  "keywords": [
    "uml",
    "diagram",
    "class diagram",
    "bpmn",
    "modeling"
  ],
  "vsce": {
    "dependencies": false
  },
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Diagrams render and edit normally. Writing sibling image exports is disabled until you trust the workspace."
    }
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "apollon.diagramEditor",
        "displayName": "Apollon Diagram",
        "selector": [
          {
            "filenamePattern": "*.apollon"
          }
        ],
        "priority": "default"
      }
    ],
    "languages": [
      {
        "id": "apollon",
        "aliases": [
          "Apollon Diagram"
        ],
        "extensions": [
          ".apollon"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./media/apollon-type.svg",
          "dark": "./media/apollon-type.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "apollon",
        "scopeName": "source.apollon",
        "path": "./syntaxes/apollon.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "apollon.newDiagram",
        "title": "New Diagram",
        "category": "Apollon",
        "icon": "$(add)"
      },
      {
        "command": "apollon.exportDiagram",
        "title": "Export Diagram as Image",
        "category": "Apollon",
        "icon": "$(export)"
      },
      {
        "command": "apollon.refreshDiagrams",
        "title": "Refresh Diagrams",
        "category": "Apollon",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "apollon.newDiagram",
          "when": "view == apollon.diagrams",
          "group": "navigation@1"
        },
        {
          "command": "apollon.refreshDiagrams",
          "when": "view == apollon.diagrams",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "apollon.refreshDiagrams",
          "when": "false"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "apollon",
          "title": "Apollon",
          "icon": "media/apollon-icon.svg"
        }
      ]
    },
    "views": {
      "apollon": [
        {
          "id": "apollon.diagrams",
          "name": "Diagrams"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "apollon.diagrams",
        "contents": "No diagrams in this workspace yet.\n[New Diagram](command:apollon.newDiagram)"
      }
    ],
    "configuration": {
      "title": "Apollon",
      "properties": {
        "apollon.autoExport": {
          "type": "string",
          "enum": [
            "off",
            "svg",
            "png"
          ],
          "enumDescriptions": [
            "Never write a sibling image.",
            "Write a sibling .svg on every save.",
            "Write a sibling .png on every save."
          ],
          "default": "off",
          "scope": "resource",
          "markdownDescription": "Write a sibling image (`diagram.svg` / `diagram.png`) next to a `.apollon` file whenever it is saved. Requires a trusted workspace."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build:all",
    "compile": "vite build",
    "watch": "vite build --watch",
    "build": "NODE_ENV=production vite build",
    "lint": "eslint src webview/src",
    "lint:fix": "eslint --fix src webview/src",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p webview/tsconfig.json --noEmit",
    "test": "vitest run",
    "package:vsix": "vsce package --no-dependencies",
    "start:webview": "pnpm --filter apollon-vscode-webview run start",
    "build:webview": "pnpm --filter apollon-vscode-webview run build",
    "build:all": "pnpm run build && pnpm run build:webview"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/node": "catalog:",
    "@types/vscode": "~1.86.0",
    "eslint": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "globals": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@tumaet/apollon": "workspace:*",
    "jsonc-parser": "^3.3.1"
  },
  "bugs": {
    "url": "https://github.com/ls1intum/Apollon/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ls1intum/Apollon.git",
    "directory": "vscode-extension"
  }
}
