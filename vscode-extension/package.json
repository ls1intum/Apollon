{
  "name": "apollon-vscode",
  "displayName": "Apollon",
  "description": "Embeddable UML modeling editor for VS Code. Create, edit, and export UML diagrams (class, component, activity, BPMN, and more) directly inside your editor.",
  "publisher": "tumaet",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.86.0",
    "node": ">=24.15.0"
  },
  "categories": [
    "Other"
  ],
  "vsce": {
    "dependencies": false
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "apollonEditor.openDiagram",
        "title": "Open Diagram",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "apollonEditor.openDiagram",
          "when": "resourceExtname == .apollon",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "apollon",
          "title": "Apollon",
          "icon": "media/apollon-icon.svg"
        }
      ]
    },
    "views": {
      "apollon": [
        {
          "type": "webview",
          "id": "menu",
          "name": ""
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build:all",
    "compile": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "build": "webpack --mode production",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "lint:fix": "eslint --fix src",
    "test": "vscode-test",
    "package:vsix": "vsce package --no-dependencies",
    "start:menu": "pnpm --filter apollon-vscode-menu run start",
    "start:editor": "pnpm --filter apollon-vscode-editor run start",
    "build:webviews": "pnpm --filter apollon-vscode-menu run build && pnpm --filter apollon-vscode-editor run build",
    "build:all": "pnpm run build && pnpm run build:webviews"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@types/mocha": "10.0.10",
    "@types/node": "24.12.4",
    "@types/styled-components": "5.1.36",
    "@types/vscode": "1.110.0",
    "@vscode/test-cli": "0.0.6",
    "@vscode/test-electron": "2.5.2",
    "eslint": "9.17.0",
    "globals": "15.13.0",
    "ts-loader": "9.5.7",
    "typescript": "5.7.2",
    "typescript-eslint": "8.18.1",
    "webpack": "5.105.4",
    "webpack-cli": "5.1.4"
  },
  "dependencies": {
    "@tumaet/apollon": "workspace:*",
    "styled-components": "6.4.0",
    "uuid": "11.0.3"
  },
  "bugs": {
    "url": "https://github.com/ls1intum/Apollon/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ls1intum/Apollon.git",
    "directory": "vscode-extension"
  }
}
