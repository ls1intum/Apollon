{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    "library": {
      "entry": ["lib/index.tsx", "lib/internals.ts", "lib/export/index.ts"],
      "project": ["lib/**/*.{ts,tsx}"],
      "ignoreBinaries": ["build", "run"]
    },
    "packages/ui": {
      "entry": [
        "src/components/*.{ts,tsx}",
        "src/styles/*",
        "src/**/*.stories.{ts,tsx}",
        "tests/**/*.test.{ts,tsx}"
      ],
      "project": ["src/**/*.{ts,tsx}", "tests/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@tailwindcss/vite"]
    },
    "standalone/webapp": {
      "entry": [
        "src/**/*.stories.{ts,tsx}",
        "src/stories/_support/*.{ts,tsx}",
        ".storybook/{main,preview,vitest.setup}.{ts,tsx}",
        "tests/**/*.{test,spec}.{ts,tsx}"
      ],
      "project": ["src/**/*.{ts,tsx}", "tests/**/*.{ts,tsx}"],
      "ignoreDependencies": [
        "@capacitor/file-transfer",
        "@capacitor/splash-screen",
        "@capacitor/android",
        "tailwindcss",
        "jspdf",
        "svg2pdf.js",
        "@tanstack/history"
      ]
    },
    "standalone/server": {
      "entry": ["src/workers/*.{ts,mjs}"]
    },
    "vscode-extension": {
      "ignoreBinaries": ["vsce"]
    },
    "vscode-extension/webview": {
      "entry": ["src/main.tsx"]
    },
    "docs": {
      "entry": ["sidebars.{user,library,contributor}.ts", "src/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}", "*.ts"],
      "ignoreDependencies": [
        "@docusaurus/plugin-content-docs",
        "@easyops-cn/docusaurus-search-local",
        "@easyops-cn/docusaurus-plugin-docusaurus-search-local"
      ]
    }
  }
}
