{
  "name": "@tumaet/apollon",
  "version": "4.8.0",
  "description": "Embeddable UML modeling editor. Mounts into any DOM node — works inside Angular, Vue, Svelte, vanilla JS, or React hosts.",
  "keywords": [
    "uml",
    "uml-editor",
    "diagram-editor",
    "react",
    "angular",
    "yjs"
  ],
  "homepage": "https://github.com/ls1intum/Apollon#readme",
  "bugs": {
    "url": "https://github.com/ls1intum/Apollon/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ls1intum/Apollon.git",
    "directory": "library"
  },
  "license": "MIT",
  "author": {
    "name": "TUM Applied Education Technologies",
    "url": "https://aet.cit.tum.de/"
  },
  "funding": "https://github.com/ls1intum/Apollon",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "schema"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/react.d.ts",
      "import": "./dist/react/react.js"
    },
    "./internals": {
      "types": "./dist/internals.d.ts",
      "import": "./dist/internals.js"
    },
    "./export": {
      "types": "./dist/export.d.ts",
      "import": "./dist/export.js"
    },
    "./style.css": "./dist/assets/style.css",
    "./schema": "./schema/uml-model-4.schema.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && LIB_PEERS=true vite build && rm -rf dist/react/assets",
    "build:watch": "tsc -b --watch & vite build --watch",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "size": "size-limit",
    "gen:fonts": "node scripts/gen-fonts.mjs",
    "gen:schema": "node scripts/gen-schema.mjs"
  },
  "size-limit": [
    {
      "name": "standalone entry (peers inlined)",
      "path": "dist/index.js",
      "limit": "220 kB"
    },
    {
      "name": "/react entry (peers external)",
      "path": "dist/react/react.js",
      "limit": "112 kB"
    },
    {
      "name": "yjs sync chunk",
      "path": "dist/yjsSync-*.js",
      "limit": "210 kB"
    },
    {
      "name": "/export lazy chunk (renderers external; Inter ttf inlined)",
      "path": "dist/export.js",
      "limit": "700 kB"
    }
  ],
  "peerDependencies": {
    "@emotion/react": "^11.12.0",
    "@emotion/styled": "^11.12.0",
    "@mui/material": "^6.4.0",
    "@xyflow/react": "^12.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.0"
  },
  "peerDependenciesMeta": {
    "@emotion/react": {
      "optional": true
    },
    "@emotion/styled": {
      "optional": true
    },
    "@mui/material": {
      "optional": true
    },
    "@xyflow/react": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@chenglou/pretext": "0.0.6",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "uuid": "catalog:",
    "zustand": "catalog:"
  },
  "optionalDependencies": {
    "@resvg/resvg-wasm": "catalog:",
    "jspdf": "catalog:",
    "svg2pdf.js": "catalog:"
  },
  "devDependencies": {
    "@emotion/react": "catalog:",
    "@emotion/styled": "catalog:",
    "@eslint/js": "catalog:",
    "@mui/material": "catalog:",
    "@size-limit/preset-big-lib": "11.2.0",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@xyflow/react": "catalog:",
    "ajv": "8.20.0",
    "babel-plugin-react-compiler": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "globals": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "size-limit": "11.2.0",
    "subset-font": "2.5.0",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "typescript-json-schema": "0.67.4",
    "vite": "catalog:",
    "vite-plugin-dts": "4.3.0",
    "vitest": "catalog:",
    "y-protocols": "1.0.6",
    "yjs": "13.6.20"
  }
}
