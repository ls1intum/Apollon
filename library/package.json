{
  "name": "@tumaet/apollon",
  "version": "5.0.0",
  "description": "Embeddable UML modeling editor. Mounts into any DOM node — works inside Angular, Vue, Svelte, vanilla JS, or React hosts.",
  "keywords": [
    "uml",
    "uml-editor",
    "diagram-editor",
    "react",
    "angular",
    "yjs"
  ],
  "homepage": "https://github.com/ls1intum/Apollon#readme",
  "bugs": {
    "url": "https://github.com/ls1intum/Apollon/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ls1intum/Apollon.git",
    "directory": "library"
  },
  "license": "MIT",
  "author": {
    "name": "TUM Applied Education Technologies",
    "url": "https://aet.cit.tum.de/"
  },
  "funding": "https://github.com/ls1intum/Apollon",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "schema"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./internals": {
      "types": "./dist/internals.d.ts",
      "import": "./dist/internals.js"
    },
    "./export": {
      "types": "./dist/export.d.ts",
      "import": "./dist/export.js"
    },
    "./style.css": "./dist/assets/style.css",
    "./schema": "./schema/uml-model-4.schema.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "pnpm --filter @tumaet/ui run build && vite",
    "build": "pnpm --filter @tumaet/ui run build && tsc -b && vite build",
    "build:watch": "pnpm exec concurrently -k \"pnpm --filter @tumaet/ui run build:css:watch\" \"pnpm --filter @tumaet/ui run build:types:watch\" \"tsc -b --watch\" \"vite build --watch\"",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "pnpm --filter @tumaet/ui run build:css && vitest run",
    "test:watch": "pnpm --filter @tumaet/ui run build:css && vitest",
    "test:coverage": "pnpm --filter @tumaet/ui run build:css && vitest run --coverage",
    "size": "size-limit",
    "gen:fonts": "node scripts/gen-fonts.mjs",
    "gen:schema": "node scripts/gen-schema.mjs"
  },
  "size-limit": [
    {
      "name": "main entry (all deps external)",
      "path": "dist/index.js",
      "limit": "85 kB"
    },
    {
      "name": "/export lazy chunk (renderers external; Inter ttf inlined)",
      "path": "dist/export.js",
      "limit": "700 kB"
    }
  ],
  "peerDependencies": {
    "@xyflow/react": "^12.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.0"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "@chenglou/pretext": "0.0.8",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "lucide-react": "catalog:",
    "zustand": "catalog:"
  },
  "optionalDependencies": {
    "@resvg/resvg-wasm": "catalog:",
    "jspdf": "catalog:",
    "svg2pdf.js": "catalog:"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "catalog:",
    "@eslint/js": "catalog:",
    "@microsoft/api-extractor": "7.58.9",
    "@size-limit/preset-big-lib": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@tumaet/ui": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@xyflow/react": "catalog:",
    "ajv": "8.20.0",
    "babel-plugin-react-compiler": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "globals": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "size-limit": "catalog:",
    "subset-font": "2.5.0",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "typescript-json-schema": "0.67.4",
    "vite": "catalog:",
    "vite-plugin-dts": "5.0.3",
    "vitest": "catalog:",
    "y-protocols": "catalog:",
    "yjs": "catalog:"
  }
}
