{
  "name": "@tumaet/apollon",
  "version": "4.2.23",
  "description": "An embeddable UML modeling editor for React. 13 diagram types, SVG/PNG/PDF/JSON export, optional real-time collaboration via Yjs.",
  "keywords": [
    "apollon",
    "uml",
    "uml-editor",
    "diagram",
    "diagram-editor",
    "modeling",
    "react",
    "typescript",
    "collaborative",
    "yjs",
    "bpmn",
    "petri-net",
    "activity-diagram",
    "class-diagram",
    "flowchart"
  ],
  "homepage": "https://github.com/ls1intum/Apollon#readme",
  "bugs": {
    "url": "https://github.com/ls1intum/Apollon/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ls1intum/Apollon.git",
    "directory": "library"
  },
  "license": "MIT",
  "author": {
    "name": "TUM Applied Education Technologies",
    "url": "https://aet.cit.tum.de/"
  },
  "funding": "https://github.com/ls1intum/Apollon",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "source": "lib/index.tsx",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:watch": "tsc -b --watch & vite build --watch",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@chenglou/pretext": "0.0.6",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@emotion/react": "11.11.1",
    "@emotion/styled": "11.11.0",
    "@mui/material": "6.4.2",
    "@xyflow/react": "12.3.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "uuid": "11.0.3",
    "yjs": "13.6.20",
    "zustand": "5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.13.8",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/coverage-v8": "4.1.2",
    "eslint": "9.17.0",
    "eslint-plugin-react": "7.37.2",
    "globals": "15.13.0",
    "jsdom": "28.1.0",
    "typescript": "5.7.2",
    "typescript-eslint": "8.18.1",
    "vite": "6.4.2",
    "vite-plugin-dts": "4.3.0",
    "vitest": "4.1.2"
  }
}
