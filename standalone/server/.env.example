# Optional: All values below match the default local setup.
# You only need a .env file if you want to override these defaults.
HOST=localhost
PORT=8000
WS_PORT=4444
CORS_ORIGIN=http://localhost:5173
REDIS_URL=redis://localhost:6379

# HMAC secret for soft owner cookie (friction, not security).
# Generate with: openssl rand -hex 32
OWNER_SECRET=development-only-replace-in-production

# Versioning limits
MAX_VERSIONS_PER_DIAGRAM=50
MAX_SNAPSHOT_BYTES=5242880
MAX_DESCRIPTION_LENGTH=240
MAX_NAME_LENGTH=80
