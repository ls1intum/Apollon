{
  "name": "@tumaet/server",
  "version": "4.9.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "build": "tsc && node --eval \"require('node:fs').cpSync('assets','dist/assets',{recursive:true})\"",
    "dev": "tsx watch --clear-screen=false src/server.ts",
    "start": "node dist/src/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "migrate:string-to-json": "tsx src/scripts/migrate-string-to-json.ts"
  },
  "dependencies": {
    "@tumaet/apollon": "workspace:*",
    "@xyflow/react": "catalog:",
    "canvas": "npm:@napi-rs/canvas@1.0.1",
    "cookie": "2.0.0",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "global-jsdom": "29.0.0",
    "jsdom": "catalog:",
    "lib0": "0.2.117",
    "pdfmake": "0.3.11",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "redis": "6.0.1",
    "ulid": "3.0.2",
    "ws": "8.21.0",
    "y-protocols": "1.0.7",
    "yjs": "13.6.31",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/express-serve-static-core": "5.1.1",
    "@types/node": "catalog:",
    "@types/pdfmake": "0.3.3",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/supertest": "7.2.0",
    "@types/ws": "8.18.1",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "globals": "catalog:",
    "supertest": "7.2.2",
    "testcontainers": "12.0.3",
    "tsx": "4.22.4",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
