{
  "name": "@tumaet/server",
  "version": "4.8.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "build": "tsc && node --eval \"require('node:fs').cpSync('assets','dist/assets',{recursive:true})\"",
    "dev": "tsx watch --clear-screen=false src/server.ts",
    "start": "node dist/src/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "migrate:string-to-json": "tsx src/scripts/migrate-string-to-json.ts"
  },
  "dependencies": {
    "@tumaet/apollon": "workspace:*",
    "canvas": "npm:@napi-rs/canvas@1.0.0",
    "cookie": "1.0.2",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "5.1.0",
    "global-jsdom": "28.0.0",
    "jsdom": "catalog:",
    "lib0": "0.2.117",
    "pdfmake": "0.3.7",
    "pino": "9.6.0",
    "pino-http": "10.4.0",
    "redis": "5.11.0",
    "ulid": "2.3.0",
    "ws": "8.18.1",
    "y-protocols": "1.0.6",
    "yjs": "13.6.20",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.3",
    "@types/express-serve-static-core": "5.1.1",
    "@types/node": "catalog:",
    "@types/pdfmake": "0.3.3",
    "@types/supertest": "6.0.2",
    "@types/ws": "8.18.1",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "globals": "catalog:",
    "supertest": "7.0.0",
    "testcontainers": "10.16.0",
    "tsx": "4.19.2",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
