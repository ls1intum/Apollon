{
  "name": "@tumaet/server",
  "version": "4.4.0",
  "private": true,
  "license": "MIT",
  "dependencies": {
    "@tumaet/apollon": "*",
    "cookie": "1.0.2",
    "cors": "2.8.5",
    "dompurify": "3.3.3",
    "dotenv": "16.4.7",
    "express": "5.1.0",
    "global-jsdom": "27.0.0",
    "jsdom": "27.4.0",
    "jspdf": "4.2.1",
    "ms": "2.1.3",
    "pino": "9.6.0",
    "pino-http": "10.4.0",
    "redis": "5.11.0",
    "svg2pdf.js": "2.7.0",
    "ulid": "2.3.0",
    "ws": "8.18.1",
    "y-protocols": "1.0.6",
    "yjs": "13.6.20",
    "zod": "3.24.2"
  },
  "scripts": {
    "build": "tsc && rm -rf dist/src/workers/fonts && cp -R src/workers/fonts dist/src/workers/fonts",
    "dev": "tsx watch --clear-screen=false src/server.ts",
    "start": "node dist/src/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "migrate:string-to-json": "tsx src/scripts/migrate-string-to-json.ts"
  },
  "devDependencies": {
    "@types/cookie": "0.6.0",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.3",
    "@types/ms": "2.1.0",
    "@types/node": "22.14.0",
    "@types/supertest": "6.0.2",
    "@types/ws": "8.18.1",
    "@vitest/coverage-v8": "3.0.5",
    "supertest": "7.0.0",
    "testcontainers": "10.16.0",
    "tsx": "4.19.2",
    "typescript": "5.8.2",
    "vitest": "3.0.5"
  }
}
