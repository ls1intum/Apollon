{
  "name": "@tumaet/app",
  "private": true,
  "version": "4.4.1",
  "type": "module",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "start": "vite",
    "start:host": "vite --host",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test tests/e2e/",
    "test:e2e:ui": "playwright test tests/e2e/ --ui",
    "test:visual": "playwright test tests/visual/",
    "test:visual:update": "playwright test tests/visual/ --update-snapshots",
    "capacitor:add:android": "cap add android",
    "capacitor:add:ios": "cap add ios --packagemanager CocoaPods",
    "capacitor:sync": "cap sync",
    "capacitor:open:android": "cap open android",
    "capacitor:open:ios": "cap open ios",
    "capacitor:assets:generate:ios": "capacitor-assets generate --ios",
    "capacitor:assets:generate:android": "capacitor-assets generate --android"
  },
  "dependencies": {
    "@capacitor/android": "8.3.0",
    "@capacitor/core": "8.3.0",
    "@capacitor/file-transfer": "2.0.4",
    "@capacitor/filesystem": "8.1.2",
    "@capacitor/ios": "8.3.0",
    "@capacitor/share": "8.0.1",
    "@capacitor/splash-screen": "8.0.1",
    "@capacitor/status-bar": "8.0.2",
    "@emotion/react": "catalog:",
    "@emotion/styled": "catalog:",
    "@ionic/react": "8.7.13",
    "@mui/icons-material": "6.4.2",
    "@mui/material": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tumaet/apollon": "workspace:*",
    "capacitor-plugin-safe-area": "4.0.0",
    "clsx": "2.1.1",
    "jspdf": "4.2.1",
    "pptxgenjs": "4.0.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-markdown": "10.1.0",
    "react-router": "7.12.0",
    "react-toastify": "11.0.5",
    "remark-gfm": "4.0.1",
    "tailwindcss": "catalog:",
    "uuid": "11.0.3",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@capacitor/assets": "3.0.5",
    "@capacitor/cli": "8.3.0",
    "@eslint/js": "catalog:",
    "@playwright/test": "1.59.1",
    "@resvg/resvg-js": "2.6.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/uuid": "10.0.0",
    "@vitejs/plugin-react": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-react": "7.37.2",
    "globals": "catalog:",
    "jsdom": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "catalog:"
  }
}
