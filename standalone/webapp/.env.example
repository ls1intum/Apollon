# Optional: Override server URLs (defaults to location-relative if unset)
VITE_SERVER_URL=http://localhost:8000
VITE_SERVER_URL_WSS=ws://localhost:4444/ws

# Capacitor builds: select an environment preset (local | staging | prod)
VITE_CAPACITOR_ENV=local

# Capacitor environment presets
VITE_CAPACITOR_URL_LOCAL=http://localhost:8000
VITE_CAPACITOR_WSS_LOCAL=ws://localhost:4444/ws
VITE_CAPACITOR_URL_STAGING=https://apollon-staging.aet.cit.tum.de
VITE_CAPACITOR_WSS_STAGING=wss://apollon-staging.aet.cit.tum.de/ws
VITE_CAPACITOR_URL_PROD=https://apollon.aet.cit.tum.de
VITE_CAPACITOR_WSS_PROD=wss://apollon.aet.cit.tum.de/ws

# Optional: Capacitor-only overrides
VITE_CAPACITOR_SERVER_URL=http://localhost:8000
VITE_CAPACITOR_SERVER_URL_WSS=ws://localhost:4444/ws
