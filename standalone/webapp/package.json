{
  "name": "@tumaet/webapp",
  "private": true,
  "version": "5.0.1",
  "type": "module",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "start": "pnpm --filter @tumaet/ui run build:css && pnpm exec concurrently -k \"pnpm --filter @tumaet/ui run build:css:watch\" \"vite\"",
    "start:host": "pnpm --filter @tumaet/ui run build:css && pnpm exec concurrently -k \"pnpm --filter @tumaet/ui run build:css:watch\" \"vite --host\"",
    "build": "pnpm --filter @tumaet/ui run build:css && tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "size-limit",
    "storybook": "pnpm --filter @tumaet/ui run build:css && storybook dev -p 6006",
    "build-storybook": "pnpm --filter @tumaet/ui run build:css && storybook build",
    "test:storybook": "vitest run --config vitest.config.storybook.ts",
    "pw": "node node_modules/@playwright/test/cli.js",
    "test:e2e": "node node_modules/@playwright/test/cli.js test tests/e2e/",
    "test:e2e:ui": "node node_modules/@playwright/test/cli.js test tests/e2e/ --ui",
    "test:e2e:firefox": "PLAYWRIGHT_FIREFOX=1 node node_modules/@playwright/test/cli.js test tests/e2e/ --project=firefox",
    "test:perf": "node node_modules/@playwright/test/cli.js test --project=perf",
    "test:perf:firefox": "PLAYWRIGHT_FIREFOX=1 node node_modules/@playwright/test/cli.js test --project=perf-firefox",
    "test:visual": "node node_modules/@playwright/test/cli.js test tests/visual/",
    "test:visual:update": "node node_modules/@playwright/test/cli.js test tests/visual/ --update-snapshots",
    "capacitor:add:android": "cap add android",
    "capacitor:add:ios": "cap add ios --packagemanager CocoaPods",
    "capacitor:sync": "cap sync",
    "capacitor:open:android": "cap open android",
    "capacitor:open:ios": "cap open ios",
    "capacitor:assets:generate:ios": "capacitor-assets generate --ios",
    "capacitor:assets:generate:android": "capacitor-assets generate --android"
  },
  "dependencies": {
    "@capacitor/android": "8.4.1",
    "@capacitor/clipboard": "8.0.1",
    "@capacitor/core": "8.4.1",
    "@capacitor/file-transfer": "2.0.4",
    "@capacitor/filesystem": "8.1.2",
    "@capacitor/ios": "8.4.1",
    "@capacitor/share": "8.0.1",
    "@capacitor/splash-screen": "8.0.1",
    "@capacitor/status-bar": "8.0.2",
    "@resvg/resvg-wasm": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/history": "1.162.0",
    "@tanstack/react-router": "1.170.16",
    "@tumaet/apollon": "workspace:*",
    "@tumaet/ui": "workspace:*",
    "@xyflow/react": "catalog:",
    "clsx": "catalog:",
    "idb": "8.0.3",
    "jspdf": "catalog:",
    "lucide-react": "catalog:",
    "pptxgenjs": "4.0.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-markdown": "10.1.0",
    "react-toastify": "11.1.0",
    "remark-gfm": "4.0.1",
    "svg2pdf.js": "catalog:",
    "tailwindcss": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@capacitor/assets": "3.0.5",
    "@capacitor/cli": "8.4.1",
    "@eslint-react/eslint-plugin": "catalog:",
    "@eslint/js": "catalog:",
    "@playwright/test": "catalog:",
    "@resvg/resvg-js": "2.6.2",
    "@size-limit/file": "catalog:",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/addon-themes": "catalog:",
    "@storybook/addon-vitest": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@tanstack/router-plugin": "1.168.18",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "babel-plugin-react-compiler": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "fake-indexeddb": "6.2.5",
    "globals": "catalog:",
    "jsdom": "catalog:",
    "jszip": "3.10.1",
    "playwright": "catalog:",
    "size-limit": "catalog:",
    "storybook": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "yjs": "catalog:"
  },
  "size-limit": [
    {
      "name": "all JS incl. on-demand export chunks (gzipped) — regression ceiling; MUI/Emotion removal is separately enforced by the no-mui-emotion check",
      "path": "dist/assets/*.js",
      "gzip": true,
      "limit": "1300 kB"
    },
    {
      "name": "all CSS (gzipped) — regression ceiling; the MUI/Emotion→shadcn migration moved runtime CSS-in-JS into static CSS (one-time step up), so the budget tracks the static stylesheet, not the old Emotion baseline",
      "path": "dist/assets/*.css",
      "gzip": true,
      "limit": "35 kB"
    }
  ]
}
