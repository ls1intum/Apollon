    "@capacitor/splash-screen": "8.0.1",
    "@capacitor/status-bar": "8.0.2",
    "@emotion/react": "11.11.1",
    "@emotion/styled": "11.11.0",
    "@ionic/react": "8.7.13",
    "@mui/icons-material": "6.4.2",
    "@mui/material": "6.4.2",
    "@tailwindcss/vite": "4.0.17",
    "@tumaet/apollon": "workspace:*",
