{
  "name": "tumaet",
  "version": "1.0.0",
  "description": "Apollon monorepo — UML modeling editor (library, webapp, server, VS Code extension).",
  "private": true,
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d",
  "scripts": {
    "build": "pnpm run build:lib && concurrently \"pnpm run build:server\" \"pnpm run build:webapp\"",
    "build:lib": "pnpm --filter @tumaet/apollon run build",
    "build:server": "pnpm --filter @tumaet/server run build",
    "build:webapp": "pnpm --filter @tumaet/webapp run build",
    "build:vscode": "pnpm --filter apollon-vscode run build:all",
    "build:docs": "pnpm run build:lib && pnpm --filter @tumaet/apollon-docs run build",
    "check:doc-snippets": "pnpm run build:lib && node scripts/check-doc-snippets.mjs",
    "storybook": "pnpm --filter @tumaet/webapp run storybook",
    "build-storybook": "pnpm --filter @tumaet/webapp run build-storybook",
    "test-storybook": "pnpm --filter @tumaet/webapp run test:storybook",
    "dev": "pnpm --filter @tumaet/ui run build && node scripts/dev.mjs",
    "dev:lib": "pnpm --filter @tumaet/apollon run build:watch",
    "dev:server": "pnpm run ensure:localdb && pnpm --filter @tumaet/server run dev",
    "dev:webapp": "pnpm --filter @tumaet/webapp run start",
    "dev:vscode": "pnpm --filter apollon-vscode run watch",
    "dev:docs": "pnpm run build:lib && pnpm --filter @tumaet/apollon-docs run start",
    "start": "concurrently \"pnpm run start:server\" \"pnpm run start:webapp\"",
    "start:server": "pnpm --filter @tumaet/server run start",
    "start:webapp": "pnpm --filter @tumaet/webapp run start",
    "start:webapp:host": "pnpm --filter @tumaet/webapp run start:host",
    "start:localdb": "docker compose -f docker/compose.local.db.yml up -d",
    "wait:localdb": "node scripts/wait-for-redis.mjs",
    "ensure:localdb": "pnpm run start:localdb && pnpm run wait:localdb",
    "lint": "concurrently \"pnpm run lint:ui\" \"pnpm run lint:lib\" \"pnpm run lint:server\" \"pnpm run lint:webapp\" \"pnpm run lint:vscode\" \"pnpm run lint:docs\"",
    "lint:ui": "pnpm --filter @tumaet/ui run lint",
    "lint:lib": "pnpm --filter @tumaet/apollon run lint",
    "lint:server": "pnpm --filter @tumaet/server run lint",
    "lint:webapp": "pnpm --filter @tumaet/webapp run lint",
    "lint:vscode": "pnpm --filter apollon-vscode run lint",
    "lint:docs": "pnpm --filter @tumaet/apollon-docs run lint",
    "lint:fix": "concurrently \"pnpm run lint:fix:ui\" \"pnpm run lint:fix:lib\" \"pnpm run lint:fix:server\" \"pnpm run lint:fix:webapp\" \"pnpm run lint:fix:vscode\"",
    "lint:fix:ui": "pnpm --filter @tumaet/ui run lint:fix",
    "lint:fix:lib": "pnpm --filter @tumaet/apollon run lint:fix",
    "lint:fix:server": "pnpm --filter @tumaet/server run lint:fix",
    "lint:fix:webapp": "pnpm --filter @tumaet/webapp run lint:fix",
    "lint:fix:vscode": "pnpm --filter apollon-vscode run lint:fix",
    "format": "prettier --ignore-path .prettierignore --write \"**/*.+(js|mjs|cjs|ts|tsx|json|md|mdx|yml|yaml)\"",
    "format:check": "prettier --ignore-path .prettierignore --check \"**/*.+(js|mjs|cjs|ts|tsx|json|md|mdx|yml|yaml)\"",
    "test": "pnpm --filter @tumaet/apollon run test",
    "test:e2e": "pnpm --filter @tumaet/webapp run test:e2e",
    "knip": "knip",
    "sync:version": "node scripts/sync-library-version.mjs",
    "sync:version:check": "node scripts/sync-library-version.mjs --check",
    "changeset": "changeset",
    "changeset:version": "node scripts/cascade-standalone-bump.mjs && changeset version && node scripts/sync-library-version.mjs && pnpm install --lockfile-only --ignore-scripts",
    "prepare": "husky || true",
    "capacitor:add:android": "pnpm --filter @tumaet/webapp run capacitor:add:android",
    "capacitor:add:ios": "pnpm --filter @tumaet/webapp run capacitor:add:ios",
    "capacitor:sync": "pnpm --filter @tumaet/webapp run capacitor:sync",
    "capacitor:open:android": "pnpm --filter @tumaet/webapp run capacitor:open:android",
    "capacitor:open:ios": "pnpm --filter @tumaet/webapp run capacitor:open:ios",
    "capacitor:assets:generate:ios": "pnpm --filter @tumaet/webapp run capacitor:assets:generate:ios",
    "capacitor:assets:generate:android": "pnpm --filter @tumaet/webapp run capacitor:assets:generate:android",
    "package:vscode": "pnpm --filter apollon-vscode run package:vsix"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24.15.0",
    "pnpm": ">=11.1.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@types/node": "catalog:",
    "concurrently": "10.0.3",
    "husky": "9.1.7",
    "knip": "6.20.0",
    "lint-staged": "17.0.8",
    "prettier": "3.8.4"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,cjs,ts,tsx,json,md,mdx,yml,yaml}": "prettier --ignore-unknown --write"
  }
}
